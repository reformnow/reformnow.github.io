---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title": {% capture title %}<span class="lang-en">{{ post.title | xml_escape }}</span><span class="lang-zh">{{ post.title_zh | default: post.title | xml_escape }}</span>{% endcapture %}{{ title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {% capture categories %}{% for category in post.categories %}{% include tag-label.html tag=category %}{% unless forloop.last %}, {% endunless %}{% endfor %}{% endcapture %}{{ categories | jsonify }},
    "tags": {% capture tags %}{% for tag in post.tags %}{% include tag-label.html tag=tag %}{% unless forloop.last %}, {% endunless %}{% endfor %}{% endcapture %}{{ tags | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "content": {% capture content %}<span class="lang-en">{{ post.description | xml_escape }}</span><span class="lang-zh">{{ post.description_zh | default: post.description | xml_escape }}</span>{% endcapture %}{{ content | jsonify }},
    "full_content": {{ post.content | markdownify | strip_html | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% for page in site.pages %}
    {% if page.title and page.search != false %}
    ,
    {
      "title": {% capture title %}<span class="lang-en">{{ page.title | xml_escape }}</span><span class="lang-zh">{{ page.title_zh | default: page.title | xml_escape }}</span>{% endcapture %}{{ title | jsonify }},
      "url": {{ page.url | relative_url | jsonify }},
      "categories": "",
      "tags": "",
      "date": "",
      "content": {% capture content %}<span class="lang-en">{{ page.description | xml_escape }}</span><span class="lang-zh">{{ page.description_zh | default: page.description | xml_escape }}</span>{% endcapture %}{{ content | jsonify }},
      "full_content": {{ page.content | markdownify | strip_html | strip_newlines | jsonify }}
    }
    {% endif %}
  {% endfor %}
]
