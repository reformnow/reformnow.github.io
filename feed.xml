---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/atom+xml" />
  <link href="{{ site.url }}{{ site.baseurl }}/" rel="alternate" type="text/html" hreflang="{{ site.lang }}" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url }}{{ site.baseurl }}/feed.xml</id>
  <title type="html">{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  {% if site.social.name %}
  <author>
    <name>{{ site.social.name | xml_escape }}</name>
    <uri>{{ site.url }}{{ site.baseurl }}/</uri>
  </author>
  {% endif %}
  <rights> © {{ site.time | date: '%Y' }} {{ site.social.name }} </rights>
  <icon>{{ '/assets/img/favicons/favicon.ico' | absolute_url }}</icon>
  <logo>{{ '/assets/img/favicons/favicon-96x96.png' | absolute_url }}</logo>

  {% for post in site.posts limit:20 %}
  <entry>
    {% assign post_title = post.title %}
    {% if post.title_zh %}
      {% assign post_title = post.title_zh | append: " | " | append: post.title %}
    {% endif %}
    <title type="html">{{ post_title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post_title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post.url | absolute_url }}</id>
    <content type="html" xml:base="{{ post.url | absolute_url }}">{{ post.content | xml_escape }}</content>
    <author>
      <name>{{ site.social.name | xml_escape }}</name>
    </author>
    {% for category in post.categories %}
    <category term="{{ category | xml_escape }}" />
    {% endfor %}
    {% for tag in post.tags %}
    <category term="{{ tag | xml_escape }}" />
    {% endfor %}
    {% assign post_summary = post.description_zh | default: post.description %}
    {% if post_summary %}
    <summary type="html">{{ post_summary | strip_html | xml_escape }}</summary>
    {% endif %}
  </entry>
  {% endfor %}
</feed>
